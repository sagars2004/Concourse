# Flight data (Phase 2). Get key: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=

# Supabase (Phase 3). Get from project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (Phase 5). Get from https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# DigitalOcean Gradient (Phase 4). Model access key from DO Gradient dashboard.
# Optional: GRADIENT_CHAT_MODEL (default: llama3.3-70b-instruct)
DO_GRADIENT_API_KEY=
